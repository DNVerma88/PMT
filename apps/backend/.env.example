# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://pmt_user:pmt_password@localhost:5434/pmt_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use strong random strings (min 32 chars) – generate with: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret_minimum_32_chars_long
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=change_me_refresh_secret_minimum_32_chars_long
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_SECRET=change_me_cookie_secret_minimum_32_chars_long

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# ─── Swagger ──────────────────────────────────────────────────────────────────
# Set to false in production to disable Swagger UI
SWAGGER_ENABLED=true
