# Frontend environment variables
# Copy to .env.local and fill in values
# Vite exposes only variables prefixed with VITE_ to the browser bundle

# API base URL – in dev, Vite proxies /api to localhost:3000 so this is only
# needed if you point the frontend at a different backend in staging/production.
VITE_API_BASE_URL=http://localhost:3000

# App display name
VITE_APP_NAME=PMT

# Feature flags
VITE_ENABLE_QUERY_DEVTOOLS=true
