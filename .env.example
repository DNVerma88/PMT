# Root-level env (Docker Compose variables)
# Copy to .env and adjust values before running docker-compose

POSTGRES_USER=pmt_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=pmt_db
POSTGRES_PORT=5434

# Optional pgAdmin (run with: docker-compose --profile tools up -d)
PGADMIN_EMAIL=admin@pmt.local
PGADMIN_PASSWORD=change_me_pgadmin_password
PGADMIN_PORT=5050
